      node-observer-config.yaml: |-
        generateTopologyUrl: "http://chart-ci.topograph.svc.cluster.local:49021/v1/generate"
        provider:
          name: aws
        engine:
          name: slinky
          params:
            configUpdateMode: skeleton-only
            namespace: slurm
            podSelector:
              matchLabels:
                app.kubernetes.io/component: compute
            topologies:
              topo-default:
                clusterDefault: true
                plugin: topology/flat
              topo1:
                blockSizes:
                - 2
                - 4
                plugin: topology/block
                podSelector:
                  matchLabels:
                    app.kubernetes.io/component: compute
                    slurm.partition: topo1
              topo2:
                blockSizes:
                - 8
                - 16
                plugin: topology/block
                podSelector:
                  matchLabels:
                    app.kubernetes.io/component: compute
                    slurm.partition: topo2
              topo3:
                plugin: topology/tree
            topologyConfigPath: topology.conf
            topologyConfigmapName: slurm-config
            useDynamicNodes: true
        trigger:
          podSelector:
            matchLabels:
              app.kubernetes.io/component: compute
