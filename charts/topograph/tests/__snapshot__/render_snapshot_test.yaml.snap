        helm.sh/chart: topograph-0.4.0
      name: chart-ci-topograph-test-metrics
      namespace: topograph
    spec:
      containers:
        - args:
            - |
              set -eu
              body=$(wget -q -O - -T 10 \
                "http://chart-ci-topograph:49021/metrics")
