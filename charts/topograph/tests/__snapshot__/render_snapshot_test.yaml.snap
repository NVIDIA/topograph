renders default values.yaml:
  1: |
    apiVersion: apps/v1
    kind: DaemonSet
    metadata:
      labels:
        app.kubernetes.io/instance: chart-ci
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: node-data-broker
        app.kubernetes.io/version: v0.4.0
        helm.sh/chart: node-data-broker-0.4.0
      name: chart-ci-node-data-broker
      namespace: topograph
    spec:
      selector:
        matchLabels:
          app.kubernetes.io/instance: chart-ci
          app.kubernetes.io/name: node-data-broker
      template:
        metadata:
          labels:
            app.kubernetes.io/instance: chart-ci
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: node-data-broker
            app.kubernetes.io/version: v0.4.0
            helm.sh/chart: node-data-broker-0.4.0
        spec:
          containers:
            - command:
                - tail
                - -f
                - /dev/null
              image: curlimages/curl:8.13.0
              imagePullPolicy: IfNotPresent
              name: node-data-broker
              resources:
                limits:
                  cpu: 100m
                  memory: 128Mi
                requests:
                  cpu: 100m
                  memory: 128Mi
              securityContext: {}
          initContainers:
            - args:
                - --provider=test
                - -v=3
              command:
                - /usr/local/bin/node-data-broker-initc
              env:
                - name: NODE_NAME
                  valueFrom:
                    fieldRef:
                      fieldPath: spec.nodeName
              image: ghcr.io/nvidia/topograph:v0.4.0
              imagePullPolicy: IfNotPresent
              name: init-node-labels
          securityContext: {}
          serviceAccountName: chart-ci-node-data-broker
  2: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      name: chart-ci-node-data-broker
    rules:
      - apiGroups:
          - ""
        resources:
          - nodes
        verbs:
          - get
          - list
          - update
  3: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRoleBinding
    metadata:
      name: chart-ci-node-data-broker
    roleRef:
      apiGroup: ""
      kind: ClusterRole
      name: chart-ci-node-data-broker
    subjects:
      - apiGroup: ""
        kind: ServiceAccount
        name: chart-ci-node-data-broker
        namespace: topograph
  4: |
    apiVersion: v1
    automountServiceAccountToken: true
    kind: ServiceAccount
    metadata:
      labels:
        app.kubernetes.io/instance: chart-ci
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: node-data-broker
        app.kubernetes.io/version: v0.4.0
        helm.sh/chart: node-data-broker-0.4.0
      name: chart-ci-node-data-broker
      namespace: topograph
  5: |
    raw: |
      Helm chart has been successfully installed.
  6: |
    apiVersion: v1
    data:
      node-observer-config.yaml: |-
        generateTopologyUrl: "http://chart-ci.topograph.svc.cluster.local:49021/v1/generate"
        provider:
          name: test
        engine:
          name: k8s
        trigger:
          null
    kind: ConfigMap
    metadata:
      labels:
        app.kubernetes.io/instance: chart-ci
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: node-observer
        app.kubernetes.io/version: v0.4.0
        helm.sh/chart: node-observer-0.4.0
      name: chart-ci-node-observer
      namespace: topograph
  7: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: chart-ci
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: node-observer
        app.kubernetes.io/version: v0.4.0
        helm.sh/chart: node-observer-0.4.0
      name: chart-ci-node-observer
      namespace: topograph
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/instance: chart-ci
          app.kubernetes.io/name: node-observer
      template:
        metadata:
          annotations:
            checksum/config: 8142bb18d64df0ccc94239a2a6abdb04adb6a4bd6707486e2ece267fda13df9b
          labels:
            app.kubernetes.io/instance: chart-ci
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: node-observer
            app.kubernetes.io/version: v0.4.0
            helm.sh/chart: node-observer-0.4.0
        spec:
          containers:
            - args:
                - -v=3
              command:
                - /usr/local/bin/node-observer
              image: ghcr.io/nvidia/topograph:v0.4.0
              imagePullPolicy: IfNotPresent
              name: node-observer
              resources:
                limits:
                  cpu: 400m
                  memory: 512Mi
                requests:
                  cpu: 250m
                  memory: 256Mi
              securityContext: {}
              volumeMounts:
                - mountPath: /etc/topograph
                  name: config-volume
          initContainers:
            - args:
                - -c
                - |
                  until curl -sf "http://chart-ci.topograph.svc.cluster.local:49021/healthz" ; do
                    echo "Waiting for topograph to start ..."
                    sleep 2
                  done
              command:
                - sh
              image: curlimages/curl:8.13.0
              imagePullPolicy: IfNotPresent
              name: wait
          securityContext: {}
          serviceAccountName: chart-ci-node-observer
          volumes:
            - configMap:
                defaultMode: 420
                name: chart-ci-node-observer
              name: config-volume
  8: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      name: chart-ci-node-observer
    rules:
      - apiGroups:
          - ""
        resources:
          - nodes
          - pods
        verbs:
          - get
          - list
          - watch
  9: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRoleBinding
    metadata:
      name: chart-ci-node-observer
    roleRef:
      apiGroup: ""
      kind: ClusterRole
      name: chart-ci-node-observer
    subjects:
      - apiGroup: ""
        kind: ServiceAccount
        name: chart-ci-node-observer
        namespace: topograph
  10: |
    apiVersion: v1
    automountServiceAccountToken: true
    kind: ServiceAccount
    metadata:
      labels:
        app.kubernetes.io/instance: chart-ci
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: node-observer
        app.kubernetes.io/version: v0.4.0
        helm.sh/chart: node-observer-0.4.0
      name: chart-ci-node-observer
      namespace: topograph
  11: |
    raw: |
      1. Get the application URL by running these commands:
        export POD_NAME=$(kubectl get pods --namespace topograph -l "app.kubernetes.io/name=topograph,app.kubernetes.io/instance=chart-ci" -o jsonpath="{.items[0].metadata.name}")
        export CONTAINER_PORT=$(kubectl get pod --namespace topograph $POD_NAME -o jsonpath="{.spec.containers[0].ports[0].containerPort}")
        echo "Visit http://127.0.0.1:8080 to use your application"
        kubectl --namespace topograph port-forward $POD_NAME 8080:$CONTAINER_PORT
  12: |
    apiVersion: v1
    data:
      topograph-config.yaml: |-
        http:
          port: 49021
          ssl: false
        requestAggregationDelay: 15s
    kind: ConfigMap
    metadata:
      labels:
        app.kubernetes.io/instance: chart-ci
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: topograph
        app.kubernetes.io/version: v0.4.0
        helm.sh/chart: topograph-0.4.0
      name: chart-ci-topograph
      namespace: topograph
  13: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: chart-ci
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: topograph
        app.kubernetes.io/version: v0.4.0
        helm.sh/chart: topograph-0.4.0
      name: chart-ci-topograph
      namespace: topograph
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/instance: chart-ci
