  1: |
    apiVersion: apps/v1
    kind: DaemonSet
    metadata:
      labels:
        app.kubernetes.io/instance: chart-ci
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: node-data-broker
        app.kubernetes.io/version: v0.4.0
        helm.sh/chart: node-data-broker-0.4.0
      name: chart-ci-node-data-broker
      namespace: topograph
    spec:
      selector:
        matchLabels:
          app.kubernetes.io/instance: chart-ci
          app.kubernetes.io/name: node-data-broker
      template:
        metadata:
          labels:
            app.kubernetes.io/instance: chart-ci
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: node-data-broker
            app.kubernetes.io/version: v0.4.0
            helm.sh/chart: node-data-broker-0.4.0
        spec:
          containers:
            - command:
                - tail
                - -f
                - /dev/null
              image: ghcr.io/nvidia/topograph/ib:main
              imagePullPolicy: IfNotPresent
              name: node-data-broker
              resources:
                limits:
                  cpu: 100m
                  memory: 128Mi
                requests:
                  cpu: 100m
                  memory: 128Mi
              securityContext:
                privileged: true
              volumeMounts:
                - mountPath: /sys/class
                  name: sys-class-volume
          initContainers:
            - args:
                - --provider=infiniband-k8s
                - -v=3
                - --set=useGpuCliqueLabel=true
              command:
                - /usr/local/bin/node-data-broker-initc
              env:
                - name: NODE_NAME
                  valueFrom:
                    fieldRef:
                      fieldPath: spec.nodeName
              image: ghcr.io/nvidia/topograph:v0.4.0
              imagePullPolicy: IfNotPresent
              name: init-node-labels
              volumeMounts:
                - mountPath: /sys/class
                  name: sys-class-volume
          nodeSelector:
            nvidia.com/gpu.present: "true"
          securityContext: {}
          serviceAccountName: chart-ci-node-data-broker
          volumes:
            - hostPath:
                path: /sys/class
                type: Directory
              name: sys-class-volume
