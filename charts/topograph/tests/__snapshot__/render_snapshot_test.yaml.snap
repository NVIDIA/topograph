        generateTopologyUrl: "http://chart-ci.topograph.svc.cluster.local:49021/v1/generate"
        provider:
          name: aws
        engine:
          name: slinky
          params:
            namespace: slurm
            plugin: topology/tree
            podSelector:
              matchLabels:
                app.kubernetes.io/component: compute
            topologyConfigPath: topology.conf
            topologyConfigmapName: slurm-config
        trigger:
          podSelector:
            matchLabels:
              app.kubernetes.io/component: compute
    kind: ConfigMap
    metadata:
