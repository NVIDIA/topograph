  1: |
    apiVersion: apps/v1
    kind: DaemonSet
    metadata:
      labels:
        app.kubernetes.io/instance: chart-ci
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: node-data-broker
        app.kubernetes.io/version: v0.4.0
        helm.sh/chart: node-data-broker-0.4.0
      name: chart-ci-node-data-broker
      namespace: topograph
    spec:
      selector:
        matchLabels:
          app.kubernetes.io/instance: chart-ci
          app.kubernetes.io/name: node-data-broker
      template:
        metadata:
          labels:
            app.kubernetes.io/instance: chart-ci
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: node-data-broker
            app.kubernetes.io/version: v0.4.0
            helm.sh/chart: node-data-broker-0.4.0
        spec:
          containers:
            - command:
                - tail
                - -f
                - /dev/null
              image: curlimages/curl:8.13.0
              imagePullPolicy: IfNotPresent
              name: node-data-broker
              resources:
                limits:
                  cpu: 100m
                  memory: 128Mi
                requests:
                  cpu: 100m
                  memory: 128Mi
              securityContext: {}
          initContainers:
            - args:
                - --provider=aws
                - -v=3
              command:
                - /usr/local/bin/node-data-broker-initc
              env:
                - name: NODE_NAME
                  valueFrom:
                    fieldRef:
                      fieldPath: spec.nodeName
              image: ghcr.io/nvidia/topograph:v0.4.0
              imagePullPolicy: IfNotPresent
              name: init-node-labels
          securityContext: {}
          serviceAccountName: chart-ci-node-data-broker
